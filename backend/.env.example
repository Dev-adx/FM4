PORT=3001

# Your deployed frontend URL (e.g. https://your-site.vercel.app)
FRONTEND_URL=https://your-frontend-url.com

# Google Sheets Web App URL (from Apps Script deployment)
GOOGLE_SHEET_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Razorpay webhook secret (set in Razorpay Dashboard → Settings → Webhooks)
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
